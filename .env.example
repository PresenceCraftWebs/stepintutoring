# Copy to .env (dev) — production values are set in Cloudflare Pages build
# settings and in .env.production for APK builds. See WIRING.md.

# R2 public bucket base URL (no trailing slash).
# WIRING: replace with your bucket's public domain, e.g.
#   https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
# or better, a custom domain like https://videos.stepintutoring.org.za
VITE_R2_PUBLIC_URL=

# Admin Cloudflare Worker base URL (no trailing slash), e.g.
#   https://sit-admin.YOUR-SUBDOMAIN.workers.dev
VITE_WORKER_URL=

# Where the web build is deployed (Cloudflare Pages). The Android app fetches
# fresh curriculum.json from here so new lessons appear without a new APK.
#   https://step-in-tutoring.pages.dev
VITE_CONTENT_BASE_URL=
